{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "noImplicitAny": true,
    "strictNullChecks": true,
    "target": "ES2018",
    "lib": [
      "DOM",
      "ES2018"
    ],
    "types": [
      "node"
    ],
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": [
    "**/*.ts"
  ]
}
